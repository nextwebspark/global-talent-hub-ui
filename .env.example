# Base URL of the Spring Boot backend.
# Leave UNSET for local dev: API paths stay relative ("/api/...") and Vite's dev
# proxy (see vite.config.ts) forwards them to your local backend.
# Set for deployed builds to call the remote backend directly (cross-origin):
#   VITE_API_URL=https://gth-api.up.railway.app
# A trailing slash is stripped automatically.
VITE_API_URL=

# Optional: override the dev proxy target (defaults to http://localhost:5001).
# Only used by `npm run dev` when VITE_API_URL is unset.
# VITE_DEV_API_PROXY=http://localhost:8080
